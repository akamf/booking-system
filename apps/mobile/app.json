{
  "expo": {
    "name": "Sportshallen",
    "slug": "sportshallen",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "sportshallen",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "se.sportshallen.app"
    },
    "android": {
      "package": "se.sportshallen.app",
      "adaptiveIcon": {
        "backgroundColor": "#2f7aff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
